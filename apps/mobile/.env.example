# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and stays on your machine.

# Base URL of the StrikeMate API.
#
# Development (Expo Go on a physical device):
#   Use your machine's local IP, not localhost — the phone can't reach localhost.
#   Find your IP on Mac:  ipconfig getifaddr en0
#   Find your IP on Windows: ipconfig (look for IPv4 Address)
#
# Production:
#   Use the deployed API URL once apps/api is hosted (see issue #14).
#
EXPO_PUBLIC_API_BASE=http://localhost:3001

# League query params used by the proof-of-life screen.
# Update these if you're testing against a different league.
# Format: leagueId={id}&year={year}&season={f|s}&weekNum={week}
#
EXPO_PUBLIC_LEAGUE_QUERY="leagueId=131919&year=2025&season=f&weekNum=26"

# Your team's ID on LeagueSecretary.
# Required to enable the Matchup Intelligence screen.
#
EXPO_PUBLIC_MY_TEAM_ID=

# Handicap basis — the scratch score from which handicap is calculated (e.g. 200 or 220).
# Match this to your league rules.
#
EXPO_PUBLIC_HANDICAP_BASIS=225

# Handicap percentage as a decimal (e.g. 0.9 for 90%).
# Match this to your league rules.
#
EXPO_PUBLIC_HANDICAP_PERCENT=0.9
